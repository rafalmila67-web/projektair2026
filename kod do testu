enum class EnemyKind { NORMAL, ARMORED, FAST, BOSS, MEDIC, SLIME, SLIME_SMALL };

struct Enemy {
    int        id;
    EnemyKind  kind;
    float      pathDist, speed;
    int        health, maxHealth, reward, damage, armor = 0;
    sf::Color  color;
    float      radius;
    bool       alive = true;
    float      flashTimer = 0.f;
    float      healTimer = 0.f;
    float      stunTimer = 0.f; 
    float      bossFreezeTimer = 4.0f; 
    float      attackCooldown = 0.f; 

    sf::Vector2f pos() const { return posOnPath(pathDist); }
    bool reachedEnd() const { return pathDist >= pathLength(); }

    static Enemy make(EnemyKind k, int wave, int serial, float diffMult){
        Enemy e; e.id = wave*1000+serial; e.kind = k; e.pathDist = -randFloat(0.f,60.f);
        float waveScale = 1.f + wave*0.15f; float finalScale = waveScale * diffMult; 

        switch(k){
        case EnemyKind::NORMAL:      e.speed=110.f; e.health=e.maxHealth=int(80*finalScale); e.reward=20; e.damage=5; e.color={220,180,180}; e.radius=14.f; break;
        case EnemyKind::ARMORED:     e.speed=65.f;  e.health=e.maxHealth=int(220*finalScale); e.reward=50; e.damage=12; e.color={160,160,160}; e.radius=18.f; e.armor=15; break;
        case EnemyKind::FAST:        e.speed=210.f; e.health=e.maxHealth=int(45*finalScale); e.reward=30; e.damage=3; e.color={150,220,255}; e.radius=10.f; break;
        case EnemyKind::BOSS:        e.speed=45.f;  e.health=e.maxHealth=int(1200*finalScale); e.reward=200; e.damage=35; e.color={255,150,255}; e.radius=28.f; e.armor=30; break;
        case EnemyKind::MEDIC:       e.speed=70.f;  e.health=e.maxHealth=int(180*finalScale); e.reward=60; e.damage=8; e.color={255,255,200}; e.radius=14.f; e.armor=5; break;
        case EnemyKind::SLIME:       e.speed=50.f;  e.health=e.maxHealth=int(260*finalScale); e.reward=40; e.damage=10; e.color={100,255,100}; e.radius=20.f; break;
        case EnemyKind::SLIME_SMALL: e.speed=230.f; e.health=e.maxHealth=int(25*finalScale); e.reward=10; e.damage=2; e.color={100,255,100}; e.radius=8.f; break;
        }
        return e;
    }

    void takeDamage(int dmg){
        dmg = std::max(1, dmg - armor);
        health -= dmg; flashTimer = 0.12f;
        if(health<=0){ health=0; alive=false; }
    }

    void updateTimers(float dt){
        if(flashTimer>0.f) flashTimer-=dt;
        if(stunTimer>0.f) stunTimer-=dt;
    }

    void draw(sf::RenderWindow& w) const {
        if(!alive) return;
        sf::Vector2f p = pos();
        
        sf::CircleShape shadow(radius*1.1f); shadow.setOrigin({radius*1.1f,radius*1.1f});
        shadow.setPosition({p.x+3,p.y+10}); shadow.setFillColor({0,0,0,80});
        shadow.setScale({1.f, 0.4f}); 
        w.draw(shadow);

        sf::CircleShape body(radius); body.setOrigin({radius,radius}); body.setPosition(p);
        sf::Color finalColor = flashTimer>0.f ? sf::Color::White : color;
        if (stunTimer > 0.f) finalColor = {200, 200, 100}; 
        body.setFillColor(finalColor);
        if(kind==EnemyKind::ARMORED || kind==EnemyKind::BOSS){ body.setOutlineThickness(3.f); body.setOutlineColor(kind==EnemyKind::BOSS?sf::Color(255,150,255):sf::Color::Yellow); }
        else if(kind==EnemyKind::MEDIC) { body.setOutlineThickness(2.f); body.setOutlineColor({255,255,255}); }
        w.draw(body);

        float pct = float(health)/float(maxHealth); float bw = radius*2.5f;
        sf::RectangleShape hbg({bw,6.f}), hfg({bw*pct,6.f});
        hbg.setFillColor({60,0,0}); hbg.setPosition({p.x-bw/2,p.y-radius-15});
        hfg.setFillColor(pct>0.5f?sf::Color::Green:pct>0.2f?sf::Color::Yellow:sf::Color::Red);
        hfg.setPosition({p.x-bw/2,p.y-radius-15});
        w.draw(hbg); w.draw(hfg);
    }
};

